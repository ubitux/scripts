#!/usr/bin/env zsh

set -eu

. "$(dirname "$0")/config"
. "$(dirname "$0")/helpers/wayland"

while getopts 'd:es' o; do
    case $o in
        d) delay=$OPTARG ;;
        e) editor=$SHOT_EDITOR ;;
        s) if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
               # Assumes sway.
               sel="-g $(swayselect)"
           else
               sel=$(slop -f "-i %i -g %g")
           fi
           test -z $sel && exit 1
           ;;
    esac
done
shift $((OPTIND-1))
f=${1:-$(date +%F-%H%M%S)-$(pwgen).png}
test -z ${delay:-} || sleep $delay
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    grim ${sel:-} $f && echo $f
else
    shotgun ${=sel:-} $f && echo $f
fi
test -z ${editor:-} || $editor $f
