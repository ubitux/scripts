#!/bin/sh

. "$(dirname "$0")/helpers/wayland"

set -eu

fullscreen=0
transcode=1
audio=0
while getopts 'fa:n' o; do
    case $o in
        f) fullscreen=1 ;;
        a) audio=$OPTARG ;;  # use pactl list short sources
        n) transcode=0 ;;
        *) exit 1 ;;
    esac
done
shift $((OPTIND-1))

if [ $# -ne 1 ]; then
    echo "Usage: $0 <base_name>" 1>&2
    exit 1
fi

base_name=$1
ofile="$base_name.mp4"

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    cmd="wf-recorder"

    if [ $fullscreen -eq 0 ]; then
        cmd="$cmd -g \"\$(swayselect)\""
    fi

    if [ "$audio" != 0 ]; then
        cmd="$cmd -f pulse -ac 2 -i $audio"
    fi

    # crf=-1 is necessary to undo the default from wf-recorder
    # see https://github.com/ammen99/wf-recorder/issues/130#issuecomment-3999876713
    cmd="$cmd -c libx264 -p preset=ultrafast -p crf=-1 -p qp=0 -x yuv444p -f"
else
cmd="ffmpeg -f x11grab -show_region 1 -draw_mouse 1 -r 60"

if [ $fullscreen -eq 1 ]; then
    cmd="$cmd -s \$(xrandr | grep '*' | awk '{ print \$1 }') -i :0.0"
else
    cmd="$cmd \$(slop -f '-s %wx%h -i :0.0+%x,%y')"
fi

if [ "$audio" != 0 ]; then
    cmd="$cmd -f pulse -ac 2 -i $audio"
fi

cmd="$cmd -c:v libx264 -preset ultrafast -qp 0 -pix_fmt yuv444p"  # x264 lossless
fi

if [ $transcode -eq 0 ]; then
    eval "$cmd" "$ofile"
else
    tmpfile="tmp_$base_name.mp4"
    eval "$cmd" "$tmpfile"

    # cropping for non power of 2 selections
    cmd="ffmpeg -i $tmpfile -vf 'crop=trunc(iw/2)*2:trunc(ih/2)*2' -pix_fmt yuv420p $ofile"
    eval "$cmd"
    rm -f "$tmpfile"
fi

echo "Record: $ofile"
